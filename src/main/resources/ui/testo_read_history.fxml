<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="600.0" prefWidth="800.0" spacing="20.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mac.bry.desktop.controller.TestoReadHistoryController">
   <padding>
      <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
   </padding>
   <children>
      <VBox spacing="5.0">
         <children>
            <Label styleClass="title-1" text="%testoreadhistory.historia_odczytow_rejestratorow_gxp" />
            <Label styleClass="text-muted" text="%testoreadhistory.pelen_rejestr_audytowy_audit">
               <font>
                  <Font size="14.0" />
               </font>
            </Label>
         </children>
      </VBox>
      
      <HBox alignment="CENTER_LEFT" spacing="10.0">
         <children>
            <TextField fx:id="searchField" prefHeight="35.0" prefWidth="300.0" promptText="%testoreadhistory.szukaj_po_modelu_numerze" />
            <Region HBox.hgrow="ALWAYS" />
            <Button mnemonicParsing="false" onAction="#handleRefresh" prefHeight="35.0" styleClass="button-outlined" text="%common.odswiez_liste" />
         </children>
      </HBox>
      
      <TableView fx:id="historyTable" prefHeight="400.0" prefWidth="740.0" VBox.vgrow="ALWAYS">
        <columns>
          <TableColumn fx:id="colTimestamp" prefWidth="160.0" text="%testoreadhistory.data_i_czas_odczytu" />
          <TableColumn fx:id="colUsername" prefWidth="140.0" text="%testoreadhistory.operator" />
          <TableColumn fx:id="colDetails" prefWidth="430.0" text="%testoreadhistory.szczegoly_pobranej_paczki_model" />
        </columns>
      </TableView>
   </children>
</VBox>
