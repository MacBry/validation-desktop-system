<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.mac.bry.desktop.controller.CoolingDeviceController" styleClass="content-area" stylesheets="@style.css">
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>

    <!-- NAGŁÓWEK STRONY -->
    <HBox alignment="CENTER_LEFT" spacing="20">
        <VBox HBox.hgrow="ALWAYS">
            <Label styleClass="title-1" text="%coolingdevices.ewidencja_urzadzen_chlodniczych" />
            <Label styleClass="text-muted" text="%coolingdevices.zarzadzanie_urzadzeniami_kontrolowanymi_temperaturowo" />
        </VBox>
        <Button fx:id="addDeviceButton" onAction="#handleAddNewDevice" styleClass="accent" text="%coolingdevices.dodaj_urzadzenie" style="-fx-pref-height: 38px; -fx-font-weight: bold;" />
        <Button onAction="#handleRefresh" text="%common.odswiez" style="-fx-pref-height: 38px;" />
    </HBox>

    <!-- PANEL FILTROWANIA (CARD STYLE) -->
    <HBox spacing="20" alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-background-radius: 8px; -fx-padding: 15px; -fx-border-color: #e2e8f0; -fx-border-radius: 8px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.02), 5, 0, 0, 1);">
        <children>
            <HBox alignment="CENTER_LEFT" HBox.hgrow="ALWAYS" spacing="10">
                <children>
                    <Label style="-fx-font-weight: bold; -fx-text-fill: #475569; -fx-font-size: 13px;" text="%common.szukaj" />
                    <TextField fx:id="searchField" promptText="%coolingdevices.wpisz_numer_inwentarzowy_lub" HBox.hgrow="ALWAYS" style="-fx-pref-height: 38px;" />
                </children>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="10">
                <children>
                    <Label style="-fx-font-weight: bold; -fx-text-fill: #475569; -fx-font-size: 13px;" text="%coolingdevices.typ_komory" />
                    <ComboBox fx:id="chamberFilter" promptText="%coolingdevices.wybierz_typ" style="-fx-pref-height: 38px; -fx-pref-width: 200px;" />
                </children>
            </HBox>
        </children>
    </HBox>

    <!-- PODZIAŁ MASTER-DETAIL -->
    <SplitPane orientation="VERTICAL" dividerPositions="0.55" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-box-border: transparent;">
        <items>
            <!-- SEKCJA MASTER: URZĄDZENIA FIZYCZNE -->
            <VBox spacing="10" style="-fx-background-color: transparent;">
                <children>
                    <Label text="%coolingdevices.urzadzenia_chlodnicze_aktywa_fizyczne" style="-fx-font-weight: bold; -fx-text-fill: #1e293b; -fx-font-size: 14px;" />
                    <TableView fx:id="deviceTable" VBox.vgrow="ALWAYS" styleClass="audit-table">
                        <columns>
                            <TableColumn fx:id="inventoryCol" prefWidth="130" text="%coolingdevices.nr_inwentarzowy" />
                            <TableColumn fx:id="nameCol" prefWidth="180" text="%coolingdevices.nazwa_urzadzenia" />
                            <TableColumn fx:id="deptCol" prefWidth="160" text="%common.dzial_pracownia" />
                            <TableColumn fx:id="chambersCountCol" prefWidth="80" text="%coolingdevices.komory" style="-fx-alignment: CENTER;" />
                            <TableColumn fx:id="statusCol" prefWidth="140" text="%common.status" style="-fx-alignment: CENTER;" />
                            <TableColumn fx:id="actionsCol" prefWidth="250" text="%common.akcje" style="-fx-alignment: CENTER;" />
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                    </TableView>
                </children>
            </VBox>

            <!-- SEKCJA DETAIL: TABY (KOMORY I RPW) -->
            <TabPane fx:id="detailTabPane" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 8px; -fx-border-color: #e2e8f0; -fx-border-radius: 8px; -fx-padding: 5px;">
                <tabs>
                    <!-- TAB 1: KOMORY -->
                    <Tab text="%coolingdevices.komory_urzadzenia">
                        <content>
                            <VBox spacing="10" style="-fx-padding: 10px;">
                                <children>
                                    <Label fx:id="chambersTitleLabel" text="%coolingdevices.komory_wybranego_urzadzenia" style="-fx-font-weight: bold; -fx-text-fill: #1e293b; -fx-font-size: 14px;" />
                                    <TableView fx:id="chambersDetailsTable" VBox.vgrow="ALWAYS" styleClass="audit-table">
                                        <columns>
                                            <TableColumn fx:id="detChamberNameCol" prefWidth="150" text="%common.nazwa_komory" />
                                            <TableColumn fx:id="detChamberTypeCol" prefWidth="120" text="%common.typ_komory" />
                                            <TableColumn fx:id="detChamberRangeCol" prefWidth="140" text="%common.zakres_roboczy" style="-fx-alignment: CENTER;" />
                                            <TableColumn fx:id="detChamberVolumeCol" prefWidth="100" text="%common.objetosc" style="-fx-alignment: CENTER;" />
                                            <TableColumn fx:id="detChamberPdaCol" prefWidth="110" text="%coolingdevices.klasa_pda" style="-fx-alignment: CENTER;" />
                                            <TableColumn fx:id="detChamberRevalCol" prefWidth="180" text="%coolingdevices.status_rewalidacji_gxp" style="-fx-alignment: CENTER;" />
                                            <TableColumn fx:id="detChamberMaterialCol" prefWidth="140" text="%coolingdevices.przechowywany_material" />
                                        </columns>
                                        <columnResizePolicy>
                                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                        </columnResizePolicy>
                                    </TableView>
                                </children>
                            </VBox>
                        </content>
                    </Tab>
                    
                    <!-- TAB 2: ROZNE PLANY WALIDACJI (RPW) -->
                    <Tab text="%coolingdevices.roczne_plany_walidacji_rpw">
                        <content>
                            <VBox spacing="10" style="-fx-padding: 10px;">
                                <children>
                                    <HBox alignment="CENTER_LEFT" spacing="10">
                                        <children>
                                            <Label fx:id="rpwTitleLabel" text="%coolingdevices.historia_planow_walidacji_urzadzenia" style="-fx-font-weight: bold; -fx-text-fill: #1e293b; -fx-font-size: 14px;" HBox.hgrow="ALWAYS" />
                                            <Pane HBox.hgrow="ALWAYS" />
                                            <Button fx:id="addRpwButton" text="%coolingdevices.dodaj_numer_rpw" onAction="#handleAddRpw" styleClass="accent" />
                                            <Button fx:id="deleteRpwButton" text="%common.usun" onAction="#handleDeleteRpw" styleClass="danger" />
                                        </children>
                                    </HBox>
                                    <TableView fx:id="rpwTable" VBox.vgrow="ALWAYS" styleClass="audit-table">
                                        <columns>
                                            <TableColumn fx:id="rpwYearCol" prefWidth="150" text="%coolingdevices.rok" style="-fx-alignment: CENTER-LEFT;" />
                                            <TableColumn fx:id="rpwNumberCol" prefWidth="150" text="%coolingdevices.numer_planu" style="-fx-alignment: CENTER-LEFT;" />
                                            <TableColumn fx:id="rpwFormattedCol" prefWidth="300" text="%coolingdevices.sformatowany_numer_rpw" style="-fx-alignment: CENTER-LEFT;" />
                                        </columns>
                                        <columnResizePolicy>
                                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                        </columnResizePolicy>
                                    </TableView>
                                </children>
                            </VBox>
                        </content>
                    </Tab>
                </tabs>
            </TabPane>
        </items>
    </SplitPane>

    <!-- LICZNIK URZĄDZEŃ -->
    <HBox alignment="CENTER_RIGHT" spacing="10">
        <Label fx:id="deviceCountLabel" styleClass="text-small" text="%coolingdevices.znaleziono_0_urzadzen" style="-fx-font-weight: bold; -fx-text-fill: #475569;" />
    </HBox>
</VBox>
