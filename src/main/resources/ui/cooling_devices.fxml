<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.mac.bry.desktop.controller.CoolingDeviceController" styleClass="content-area" stylesheets="@style.css">
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>

    <!-- NAGŁÓWEK STRONY -->
    <HBox alignment="CENTER_LEFT" spacing="20">
        <VBox HBox.hgrow="ALWAYS">
            <Label styleClass="title-1" text="Ewidencja Urządzeń Chłodniczych" />
            <Label styleClass="text-muted" text="Zarządzanie urządzeniami kontrolowanymi temperaturowo (jedno- i wielokomorowymi) oraz ich parametrami metrologicznymi." />
        </VBox>
        <Button fx:id="addDeviceButton" onAction="#handleAddNewDevice" styleClass="accent" text="Dodaj Urządzenie" style="-fx-pref-height: 38px; -fx-font-weight: bold;" />
        <Button onAction="#handleRefresh" text="Odśwież" style="-fx-pref-height: 38px;" />
    </HBox>

    <!-- PANEL FILTROWANIA (CARD STYLE) -->
    <HBox spacing="20" alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-background-radius: 8px; -fx-padding: 15px; -fx-border-color: #e2e8f0; -fx-border-radius: 8px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.02), 5, 0, 0, 1);">
        <children>
            <HBox alignment="CENTER_LEFT" HBox.hgrow="ALWAYS" spacing="10">
                <children>
                    <Label style="-fx-font-weight: bold; -fx-text-fill: #475569; -fx-font-size: 13px;" text="Szukaj:" />
                    <TextField fx:id="searchField" promptText="Wpisz numer inwentarzowy lub nazwę..." HBox.hgrow="ALWAYS" style="-fx-pref-height: 38px;" />
                </children>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="10">
                <children>
                    <Label style="-fx-font-weight: bold; -fx-text-fill: #475569; -fx-font-size: 13px;" text="Typ komory:" />
                    <ComboBox fx:id="chamberFilter" promptText="Wybierz typ" style="-fx-pref-height: 38px; -fx-pref-width: 200px;" />
                </children>
            </HBox>
        </children>
    </HBox>

    <!-- PODZIAŁ MASTER-DETAIL -->
    <SplitPane orientation="VERTICAL" dividerPositions="0.55" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-box-border: transparent;">
        <items>
            <!-- SEKCJA MASTER: URZĄDZENIA FIZYCZNE -->
            <VBox spacing="10" style="-fx-background-color: transparent;">
                <children>
                    <Label text="Urządzenia Chłodnicze (Aktywa fizyczne)" style="-fx-font-weight: bold; -fx-text-fill: #1e293b; -fx-font-size: 14px;" />
                    <TableView fx:id="deviceTable" VBox.vgrow="ALWAYS" styleClass="audit-table">
                        <columns>
                            <TableColumn fx:id="inventoryCol" prefWidth="130" text="Nr Inwentarzowy" />
                            <TableColumn fx:id="nameCol" prefWidth="180" text="Nazwa urządzenia" />
                            <TableColumn fx:id="deptCol" prefWidth="160" text="Dział / Pracownia" />
                            <TableColumn fx:id="chambersCountCol" prefWidth="80" text="Komory" style="-fx-alignment: CENTER;" />
                            <TableColumn fx:id="statusCol" prefWidth="140" text="Status" style="-fx-alignment: CENTER;" />
                            <TableColumn fx:id="actionsCol" prefWidth="250" text="Akcje" style="-fx-alignment: CENTER;" />
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                    </TableView>
                </children>
            </VBox>

            <!-- SEKCJA DETAIL: TABY (KOMORY I RPW) -->
            <TabPane fx:id="detailTabPane" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 8px; -fx-border-color: #e2e8f0; -fx-border-radius: 8px; -fx-padding: 5px;">
                <tabs>
                    <!-- TAB 1: KOMORY -->
                    <Tab text="Komory Urządzenia">
                        <content>
                            <VBox spacing="10" style="-fx-padding: 10px;">
                                <children>
                                    <Label fx:id="chambersTitleLabel" text="Komory wybranego urządzenia" style="-fx-font-weight: bold; -fx-text-fill: #1e293b; -fx-font-size: 14px;" />
                                    <TableView fx:id="chambersDetailsTable" VBox.vgrow="ALWAYS" styleClass="audit-table">
                                        <columns>
                                            <TableColumn fx:id="detChamberNameCol" prefWidth="150" text="Nazwa komory" />
                                            <TableColumn fx:id="detChamberTypeCol" prefWidth="120" text="Typ komory" />
                                            <TableColumn fx:id="detChamberRangeCol" prefWidth="140" text="Zakres roboczy" style="-fx-alignment: CENTER;" />
                                            <TableColumn fx:id="detChamberVolumeCol" prefWidth="100" text="Objętość" style="-fx-alignment: CENTER;" />
                                            <TableColumn fx:id="detChamberPdaCol" prefWidth="110" text="Klasa PDA" style="-fx-alignment: CENTER;" />
                                            <TableColumn fx:id="detChamberRevalCol" prefWidth="180" text="Status rewalidacji GxP" style="-fx-alignment: CENTER;" />
                                            <TableColumn fx:id="detChamberMaterialCol" prefWidth="140" text="Przechowywany materiał" />
                                        </columns>
                                        <columnResizePolicy>
                                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                        </columnResizePolicy>
                                    </TableView>
                                </children>
                            </VBox>
                        </content>
                    </Tab>
                    
                    <!-- TAB 2: ROZNE PLANY WALIDACJI (RPW) -->
                    <Tab text="Roczne Plany Walidacji (RPW)">
                        <content>
                            <VBox spacing="10" style="-fx-padding: 10px;">
                                <children>
                                    <HBox alignment="CENTER_LEFT" spacing="10">
                                        <children>
                                            <Label fx:id="rpwTitleLabel" text="Historia planów walidacji urządzenia" style="-fx-font-weight: bold; -fx-text-fill: #1e293b; -fx-font-size: 14px;" HBox.hgrow="ALWAYS" />
                                            <Pane HBox.hgrow="ALWAYS" />
                                            <Button fx:id="addRpwButton" text="Dodaj numer RPW" onAction="#handleAddRpw" styleClass="accent" />
                                            <Button fx:id="deleteRpwButton" text="Usuń" onAction="#handleDeleteRpw" styleClass="danger" />
                                        </children>
                                    </HBox>
                                    <TableView fx:id="rpwTable" VBox.vgrow="ALWAYS" styleClass="audit-table">
                                        <columns>
                                            <TableColumn fx:id="rpwYearCol" prefWidth="150" text="Rok" style="-fx-alignment: CENTER-LEFT;" />
                                            <TableColumn fx:id="rpwNumberCol" prefWidth="150" text="Numer planu" style="-fx-alignment: CENTER-LEFT;" />
                                            <TableColumn fx:id="rpwFormattedCol" prefWidth="300" text="Sformatowany numer RPW" style="-fx-alignment: CENTER-LEFT;" />
                                        </columns>
                                        <columnResizePolicy>
                                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                        </columnResizePolicy>
                                    </TableView>
                                </children>
                            </VBox>
                        </content>
                    </Tab>
                </tabs>
            </TabPane>
        </items>
    </SplitPane>

    <!-- LICZNIK URZĄDZEŃ -->
    <HBox alignment="CENTER_RIGHT" spacing="10">
        <Label fx:id="deviceCountLabel" styleClass="text-small" text="Znaleziono: 0 urządzeń" style="-fx-font-weight: bold; -fx-text-fill: #475569;" />
    </HBox>
</VBox>
