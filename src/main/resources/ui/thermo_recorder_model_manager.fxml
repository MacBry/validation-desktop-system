<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" stylesheets="@style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mac.bry.desktop.controller.ThermoRecorderModelManagerController">
    <padding>
        <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="20">
        <Label styleClass="title-1" text="%thermorecordermodelmanager.menedzer_modeli_rejestratorow" />
        <Region HBox.hgrow="ALWAYS" />
        <Button onAction="#handleAddNewModel" styleClass="accent" text="%thermorecordermodelmanager.dodaj_nowy_model" />
    </HBox>

    <!-- Pasek filtrów -->
    <HBox alignment="CENTER_LEFT" spacing="15" styleClass="filter-pane">
        <padding>
            <Insets bottom="10" left="15" right="15" top="10" />
        </padding>
        <Label text="%thermorecordermodelmanager.wyszukaj" />
        <TextField fx:id="searchField" prefWidth="250" promptText="%thermorecordermodelmanager.nazwa_modelu" />
    </HBox>

    <TableView fx:id="modelsTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="idColumn" prefWidth="50" text="%common.id" />
            <TableColumn fx:id="nameColumn" prefWidth="250" text="%thermorecordermodelmanager.nazwa_modelu2" />
            <TableColumn fx:id="channelsColumn" prefWidth="120" text="%thermorecordermodelmanager.liczba_kanalow" />
            <TableColumn fx:id="resolutionColumn" prefWidth="150" text="%thermorecordermodelmanager.domyslna_rozdzielczosc" />
            <TableColumn fx:id="activeColumn" prefWidth="100" text="%common.aktywny" />
            <TableColumn fx:id="actionsColumn" prefWidth="150" text="%common.akcje" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>

</VBox>
