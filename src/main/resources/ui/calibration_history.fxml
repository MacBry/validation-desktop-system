<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.mac.bry.desktop.controller.CalibrationHistoryController" prefWidth="850" prefHeight="520" styleClass="content-area" stylesheets="@style.css">
    <padding>
        <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
    </padding>

    <!-- NAGŁÓWEK -->
    <HBox alignment="CENTER_LEFT" spacing="15">
        <VBox spacing="5">
            <Label fx:id="titleLabel" styleClass="title-2" text="Historia Wzorcowań" style="-fx-font-weight: bold; -fx-text-fill: #0f172a;" />
            <Label fx:id="recorderLabel" styleClass="text-muted" text="Rejestrator: -" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <Button onAction="#handleAddCalibration" styleClass="accent" text="Dodaj Nowe Wzorcowanie" style="-fx-pref-height: 38px; -fx-font-weight: bold;" />
    </HBox>

    <!-- TABELA DANYCH -->
    <TableView fx:id="calibrationTable" VBox.vgrow="ALWAYS" styleClass="audit-table">
        <columns>
            <TableColumn fx:id="dateColumn" prefWidth="130" text="Data Wzorcowania" />
            <TableColumn fx:id="certNumberColumn" prefWidth="160" text="Numer Świadectwa" />
            <TableColumn fx:id="validUntilColumn" prefWidth="130" text="Ważne do" />
            <TableColumn fx:id="statusColumn" prefWidth="120" text="Status" style="-fx-alignment: CENTER;" />
            <TableColumn fx:id="scanColumn" prefWidth="90" text="Skan PDF" style="-fx-alignment: CENTER;" />
            <TableColumn fx:id="actionsColumn" prefWidth="150" text="Akcje" style="-fx-alignment: CENTER;" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>

    <!-- STOPKA -->
    <HBox alignment="CENTER_RIGHT" spacing="10">
        <Button onAction="#handleClose" text="Zamknij" style="-fx-pref-height: 36px; -fx-pref-width: 100px;" />
    </HBox>
</VBox>
