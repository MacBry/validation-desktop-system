<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefWidth="1050.0" prefHeight="620.0" spacing="15.0" style="-fx-background-color: #f8fafc;" stylesheets="@style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.mac.bry.desktop.controller.SegmentAnnotationDialogController">
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
   <children>
      <!-- NAGŁÓWEK -->
      <VBox spacing="5.0">
         <children>
            <Label styleClass="title-2" text="%segmentannotationdialog.przeglad_i_adnotacja_wykrytych" style="-fx-text-fill: #0f172a;" />
            <Label text="%segmentannotationdialog.human_in_the_loop" wrapText="true" style="-fx-text-fill: #64748b; -fx-font-size: 12px;" />
         </children>
      </VBox>

      <Separator />

      <!-- FILTR -->
      <HBox spacing="15.0" alignment="CENTER_LEFT">
         <children>
            <Label text="%segmentannotationdialog.widok" style="-fx-font-weight: bold; -fx-text-fill: #475569;" />
            <CheckBox fx:id="chkOnlyEvents" text="%segmentannotationdialog.tylko_zdarzenia_defrost_drzwi" selected="true" />
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="lblCounter" text="" style="-fx-text-fill: #64748b; -fx-font-size: 12px;" />
         </children>
      </HBox>

      <!-- TABELA SEGMENTÓW -->
      <TableView fx:id="segmentTable" VBox.vgrow="ALWAYS">
         <columns>
            <TableColumn fx:id="colPosition" text="%common.pozycja" prefWidth="130.0" />
            <TableColumn fx:id="colType" text="%segmentannotationdialog.typ" prefWidth="120.0" />
            <TableColumn fx:id="colFrom" text="%segmentannotationdialog.od" prefWidth="120.0" />
            <TableColumn fx:id="colTo" text="%segmentannotationdialog.do" prefWidth="120.0" />
            <TableColumn fx:id="colDuration" text="%segmentannotationdialog.czas_min" prefWidth="70.0" />
            <TableColumn fx:id="colConfidence" text="%segmentannotationdialog.pewnosc" prefWidth="70.0" />
            <TableColumn fx:id="colNote" text="%segmentannotationdialog.sygnatura_nota" prefWidth="260.0" />
            <TableColumn fx:id="colStatus" text="%common.status" prefWidth="140.0" />
         </columns>
         <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY_FLEX_LAST_COLUMN" /></columnResizePolicy>
      </TableView>

      <!-- PRZYCISKI AKCJI -->
      <HBox spacing="10.0" alignment="CENTER_RIGHT">
         <children>
            <Label fx:id="lblSelectionHint" text="%segmentannotationdialog.zaznacz_segment_aby_go" style="-fx-text-fill: #94a3b8; -fx-font-size: 11px;" HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308" />
            <Button fx:id="btnAccept" mnemonicParsing="false" onAction="#handleAccept" text="%segmentannotationdialog.potwierdz" disable="true" style="-fx-pref-height: 36px; -fx-pref-width: 130px; -fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold;" />
            <Button fx:id="btnReject" mnemonicParsing="false" onAction="#handleReject" text="%segmentannotationdialog.odrzuc" disable="true" style="-fx-pref-height: 36px; -fx-pref-width: 130px; -fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold;" />
            <Separator orientation="VERTICAL" />
            <Button fx:id="btnAcceptAll" mnemonicParsing="false" onAction="#handleAcceptAll" text="%segmentannotationdialog.potwierdz_wszystkie" style="-fx-pref-height: 36px;" />
            <Button mnemonicParsing="false" onAction="#handleClose" text="%common.zamknij" style="-fx-pref-height: 36px; -fx-pref-width: 100px;" />
         </children>
      </HBox>
   </children>
</VBox>
