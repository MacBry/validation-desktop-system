<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.mac.bry.desktop.controller.ForcePasswordChangeController"
      style="-fx-background-color: #f4f6f9;" prefHeight="600.0" prefWidth="800.0">
    
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0"/>
    </padding>

    <Label text="%forcepasswordchange.wymagana_zmiana_hasla" textFill="#2c3e50">
        <font>
            <Font name="System Bold" size="24.0"/>
        </font>
    </Label>

    <Label text="%forcepasswordchange.administrator_wymusil_zmiane_hasla" textFill="#7f8c8d" wrapText="true" textAlignment="CENTER" maxWidth="400.0"/>

    <VBox spacing="10.0" maxWidth="300.0">
        <Label text="%forcepasswordchange.nowe_haslo"/>
        <PasswordField fx:id="newPasswordField" promptText="%common.wpisz_nowe_haslo"/>
        
        <Label text="%forcepasswordchange.powtorz_haslo"/>
        <PasswordField fx:id="confirmPasswordField" promptText="%common.powtorz_nowe_haslo"/>
    </VBox>

    <Label fx:id="errorLabel" text="%forcepasswordchange.blad" textFill="RED" visible="false"/>

    <Button text="%forcepasswordchange.zmien_haslo_i_wejdz" onAction="#handleChangePassword" 
            style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 5;"/>
</VBox>
