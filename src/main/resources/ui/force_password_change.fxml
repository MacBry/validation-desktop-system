<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.mac.bry.desktop.controller.ForcePasswordChangeController"
      style="-fx-background-color: #f4f6f9;" prefHeight="600.0" prefWidth="800.0">
    
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0"/>
    </padding>

    <Label text="Wymagana zmiana hasła" textFill="#2c3e50">
        <font>
            <Font name="System Bold" size="24.0"/>
        </font>
    </Label>

    <Label text="Administrator wymusił zmianę hasła. Zanim przejdziesz dalej, ustaw nowe hasło." textFill="#7f8c8d" wrapText="true" textAlignment="CENTER" maxWidth="400.0"/>

    <VBox spacing="10.0" maxWidth="300.0">
        <Label text="Nowe hasło:"/>
        <PasswordField fx:id="newPasswordField" promptText="Wpisz nowe hasło"/>
        
        <Label text="Powtórz hasło:"/>
        <PasswordField fx:id="confirmPasswordField" promptText="Powtórz nowe hasło"/>
    </VBox>

    <Label fx:id="errorLabel" text="Błąd" textFill="RED" visible="false"/>

    <Button text="Zmień hasło i wejdź" onAction="#handleChangePassword" 
            style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 5;"/>
</VBox>
