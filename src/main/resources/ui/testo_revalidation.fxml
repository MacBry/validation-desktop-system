                                                                             <TableColumn fx:id="colStatsStdDev" prefWidth="90.0" text="Odchylenie [°C]" style="-fx-alignment: CENTER;" reorderable="false" />
                                                                             <TableColumn fx:id="colStatsRsd" prefWidth="85.0" text="RSD [%]" style="-fx-alignment: CENTER;" reorderable="false" />
                                                                             <TableColumn fx:id="colStatsSkewness" prefWidth="80.0" text="Skośność" style="-fx-alignment: CENTER;" reorderable="false" />
                                                                             <TableColumn fx:id="colStatsKurtosis" prefWidth="80.0" text="Kurtoza" style="-fx-alignment: CENTER;" reorderable="false" />
                                                                             <TableColumn fx:id="colStatsCp" prefWidth="70.0" text="Cp" style="-fx-alignment: CENTER;" reorderable="false" />
