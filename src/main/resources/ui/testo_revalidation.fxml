                                                                           style="-fx-font-size: 11px; -fx-text-fill: -color-fg-muted;" />
                                                                    <Label fx:id="lblColdspotTemp" text="—"
                                                                           GridPane.columnIndex="1" GridPane.rowIndex="1"
                                                                           style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #1e6ab4;" />
                                                                </children>
                                                            </GridPane>
                                                        </children>
                                                    </VBox>

                                                    <!-- ROZPIĘTOŚĆ -->
                                                    <HBox spacing="8.0" alignment="CENTER_LEFT">
                                                        <children>
                                                            <Label text="Rozpiętość ΔT:" style="-fx-font-size: 11px; -fx-text-fill: -color-fg-muted;" />
                                                            <Label fx:id="lblMappingDeltaT" text="—"
                                                                   style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: -color-fg-default;" />
                                                        </children>
                                                    </HBox>
                                                </children>
                                            </VBox>

                                            <Label text="Bezpieczeństwo i Integralność GxP" style="-fx-font-weight: bold; -fx-font-size: 11px; -fx-text-fill: -color-fg-muted;" />
                                            
                                            <Label text="Skompilowany raport będzie zawierać kryptograficzną sumę kontrolną SHA-256 z kompletnej macierzy pomiarowej wszystkich wgranych narożników komory chłodniczej, co gwarantuje pełną zgodność z wytycznymi FDA 21 CFR Part 11." style="-fx-font-size: 11px; -fx-text-fill: -color-fg-muted;" wrapText="true" />
                                            
                                            <Region VBox.vgrow="ALWAYS" />
                                            
                                            <Label fx:id="lblValidationSummary" text="Weryfikacja spójności danych..." style="-fx-font-weight: bold; -fx-text-fill: -color-success-emphasis;" wrapText="true" />
