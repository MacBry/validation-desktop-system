<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.mac.bry.desktop.controller.ProceduresListController" styleClass="content-area">
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>

    <!-- NAGŁÓWEK STRONY -->
    <HBox alignment="CENTER_LEFT" spacing="20">
        <VBox HBox.hgrow="ALWAYS">
            <Label styleClass="title-1" text="%procedureslist.przeprowadzone_procedury_gxp" />
            <Label styleClass="text-muted" text="%procedureslist.spis_wszystkich_zsynchronizowanych_rewalidacji" />
        </VBox>
        <Button onAction="#handleRefresh" text="%common.odswiez_liste" style="-fx-pref-height: 38px;" styleClass="accent" />
    </HBox>

    <!-- VERTICAL SPLIT PANE FOR MASTER-DETAIL -->
    <SplitPane dividerPositions="0.6" VBox.vgrow="ALWAYS" styleClass="premium-split-pane" orientation="VERTICAL" style="-fx-background-color: transparent;">
        <items>
            <!-- GÓRA: TABELA PROCEDUR -->
            <VBox spacing="10">
                <TableView fx:id="proceduresTable" VBox.vgrow="ALWAYS" styleClass="audit-table">
                    <columns>
                        <TableColumn fx:id="typeCol" prefWidth="240" text="%procedureslist.typ_procedury" />
                        <TableColumn fx:id="locationCol" prefWidth="240" text="%procedureslist.urzadzenie_komora" />
                        <TableColumn fx:id="dateCol" prefWidth="150" text="%procedureslist.data_importu" style="-fx-alignment: CENTER;" />
                        <TableColumn fx:id="sensorsCol" prefWidth="180" text="%procedureslist.sensory_s_n" />
                        <TableColumn fx:id="countCol" prefWidth="90" text="%common.pomiary" style="-fx-alignment: CENTER;" />
                        <TableColumn fx:id="statusCol" prefWidth="120" text="%procedureslist.status_gxp" style="-fx-alignment: CENTER;" />
                        <TableColumn fx:id="actionsCol" prefWidth="140" text="%procedureslist.raport_pdf" style="-fx-alignment: CENTER;" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </VBox>

            <!-- DÓŁ: PANEL SZCZEGÓŁÓW METROLOGICZNYCH -->
            <VBox fx:id="detailsContainer" spacing="10" style="-fx-background-color: -color-bg-overlay; -fx-padding: 15; -fx-background-radius: 8px; -fx-border-color: -color-border-default; -fx-border-width: 1px;">
                <children>
                    <!-- Placeholder gdy brak wyboru -->
                    <StackPane fx:id="placeholderPane" VBox.vgrow="ALWAYS">
                        <Label text="%procedureslist.wybierz_procedure_z_powyzszej" styleClass="text-muted" style="-fx-font-style: italic; -fx-font-size: 13px;" />
                    </StackPane>

                    <!-- Główny kontener szczegółów (domyślnie ukryty) -->
                    <VBox fx:id="detailsContent" spacing="10" VBox.vgrow="ALWAYS" visible="false" managed="false">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label fx:id="lblDetailsTitle" text="%procedureslist.analiza_metrologiczna_serii_pomiarowych" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: -color-accent-emphasis;" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Label fx:id="lblDetailsDate" styleClass="text-muted" style="-fx-font-size: 11px;" />
                        </HBox>
                        <TableView fx:id="detailsTableView" VBox.vgrow="ALWAYS" styleClass="audit-table">
                            <columns>
                                <TableColumn fx:id="colDetailPos" prefWidth="120" text="%common.fizyczna_pozycja" reorderable="false" />
                                <TableColumn fx:id="colDetailSn" prefWidth="110" text="%common.s_n" reorderable="false" />
                                <TableColumn fx:id="colDetailMin" prefWidth="80" text="%common.t_min_c" style="-fx-alignment: CENTER;" reorderable="false" />
                                <TableColumn fx:id="colDetailMax" prefWidth="80" text="%common.t_max_c" style="-fx-alignment: CENTER;" reorderable="false" />
                                <TableColumn fx:id="colDetailAvg" prefWidth="80" text="%common.t_avg_c" style="-fx-alignment: CENTER;" reorderable="false" />
                                <TableColumn fx:id="colDetailMkt" prefWidth="80" text="%common.mkt_c" style="-fx-alignment: CENTER;" reorderable="false" />
                                <TableColumn fx:id="colDetailUncertainty" prefWidth="100" text="%common.niepewnosc_u" style="-fx-alignment: CENTER;" reorderable="false" />
                                <TableColumn fx:id="colDetailSpikes" prefWidth="80" text="%common.szpilki" style="-fx-alignment: CENTER;" reorderable="false" />
                                <TableColumn fx:id="colDetailDrift" prefWidth="120" text="%common.klasyfikacja" style="-fx-alignment: CENTER;" reorderable="false" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </VBox>
                </children>
            </VBox>
        </items>
    </SplitPane>

    <!-- LICZNIK PROCEDUR -->
    <HBox alignment="CENTER_RIGHT" spacing="10">
        <Label fx:id="proceduresCountLabel" styleClass="text-small" text="%procedureslist.lacznie_0_procedur" style="-fx-font-weight: bold; -fx-text-fill: #475569;" />
    </HBox>
</VBox>
