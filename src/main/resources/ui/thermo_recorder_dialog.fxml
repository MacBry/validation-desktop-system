<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.mac.bry.desktop.controller.ThermoRecorderDialogController" prefWidth="450">
    <padding>
        <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
    </padding>

    <Label styleClass="title-2" text="%thermorecorderdialog.dane_rejestratora" />
    
    <GridPane hgap="15" vgap="15">
        <columnConstraints>
            <ColumnConstraints prefWidth="120" />
            <ColumnConstraints hgrow="ALWAYS" />
        </columnConstraints>

        <Label text="%thermorecorderdialog.numer_seryjny" GridPane.rowIndex="0" />
        <TextField fx:id="snField" GridPane.columnIndex="1" GridPane.rowIndex="0" />

        <Label text="%common.model2" GridPane.rowIndex="1" />
        <ComboBox fx:id="modelComboBox" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="1" />

        <Label text="%common.status2" GridPane.rowIndex="2" />
        <ComboBox fx:id="statusComboBox" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="2" />

        <Label text="%common.rozdzielczosc_c" GridPane.rowIndex="3" />
        <TextField fx:id="resolutionField" promptText="%thermorecorderdialog.np_0_1" GridPane.columnIndex="1" GridPane.rowIndex="3" />

        <Label text="%common.dzial2" GridPane.rowIndex="4" />
        <ComboBox fx:id="deptComboBox" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="4" />

        <Label text="%common.pracownia2" GridPane.rowIndex="5" />
        <ComboBox fx:id="labComboBox" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="5" />
    </GridPane>

    <Separator />

    <HBox alignment="CENTER_RIGHT" spacing="10">
        <Button onAction="#handleCancel" text="%common.anuluj" />
        <Button onAction="#handleSave" styleClass="accent" text="%common.zapisz" />
    </HBox>
</VBox>
