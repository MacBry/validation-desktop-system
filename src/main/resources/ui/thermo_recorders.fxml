<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<VBox spacing="20" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.mac.bry.desktop.controller.ThermoRecorderController" styleClass="content-area">
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>

    <!-- NAGŁÓWEK STRONY -->
    <HBox alignment="CENTER_LEFT" spacing="20">
        <VBox HBox.hgrow="ALWAYS">
            <Label styleClass="title-1" text="Rejestratory Temperatury" />
            <Label styleClass="text-muted" text="Zarządzanie bazą urządzeń pomiarowych i ich wzorcowaniem." />
        </VBox>
        <Button onAction="#handleAddNewRecorder" styleClass="accent" text="Dodaj Rejestrator" style="-fx-pref-height: 38px; -fx-font-weight: bold;" />
        <Button onAction="#handleRefresh" text="Odśwież" style="-fx-pref-height: 38px;" />
    </HBox>

    <!-- PANEL FILTROWANIA (CARD STYLE) -->
    <HBox spacing="20" alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-background-radius: 8px; -fx-padding: 15px; -fx-border-color: #e2e8f0; -fx-border-radius: 8px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.02), 5, 0, 0, 1);">
        <children>
            <HBox alignment="CENTER_LEFT" HBox.hgrow="ALWAYS" spacing="10">
                <children>
                    <Label style="-fx-font-weight: bold; -fx-text-fill: #475569; -fx-font-size: 13px;" text="Szukaj:" />
                    <TextField fx:id="searchField" promptText="Wpisz numer seryjny (S/N) lub model..." HBox.hgrow="ALWAYS" style="-fx-pref-height: 38px;" />
                </children>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="10">
                <children>
                    <Label style="-fx-font-weight: bold; -fx-text-fill: #475569; -fx-font-size: 13px;" text="Status:" />
                    <ComboBox fx:id="statusFilter" promptText="Wybierz status" style="-fx-pref-height: 38px; -fx-pref-width: 160px;" />
                </children>
            </HBox>
        </children>
    </HBox>

    <!-- TABELA DANYCH -->
    <TableView fx:id="recorderTable" VBox.vgrow="ALWAYS" styleClass="audit-table">
        <columns>
            <TableColumn fx:id="snColumn" prefWidth="140" text="Numer Seryjny" />
            <TableColumn fx:id="modelColumn" prefWidth="130" text="Model" />
            <TableColumn fx:id="deptColumn" prefWidth="180" text="Dział / Pracownia" />
            <TableColumn fx:id="statusColumn" prefWidth="120" text="Status" style="-fx-alignment: CENTER;" />
            <TableColumn fx:id="calibrationColumn" prefWidth="200" text="Ważność Wzorcowania" style="-fx-alignment: CENTER;" />
            <TableColumn fx:id="actionsColumn" prefWidth="250" text="Akcje" style="-fx-alignment: CENTER;" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>

    <!-- LICZNIK REJESTRATORÓW -->
    <HBox alignment="CENTER_RIGHT" spacing="10">
        <Label fx:id="recordCountLabel" styleClass="text-small" text="Znaleziono: 0 rejestratorów" style="-fx-font-weight: bold; -fx-text-fill: #475569;" />
    </HBox>
</VBox>
