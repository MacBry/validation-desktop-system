<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.mac.bry.desktop.controller.StatsDiagnosticsDialogController"
      prefWidth="960" prefHeight="740" styleClass="content-area" stylesheets="@style.css">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <!-- NAGŁÓWEK DIALOGU -->
    <VBox spacing="5.0">
        <children>
            <Label fx:id="lblSensorTitle" styleClass="title-2" text="Zaawansowana Diagnostyka SPC &amp; Defrost"
                   style="-fx-font-weight: bold; -fx-text-fill: -color-accent-emphasis;" />
            <Label fx:id="lblSpcStats" text="Wskaźniki SPC: Cp = — | Cpk = —"
                   style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: -color-fg-muted;" />
        </children>
    </VBox>

    <Separator />

    <!-- GŁÓWNA ZAWARTOŚĆ (TABPANE) -->
    <TabPane VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE">
        <tabs>

            <!-- ZAKŁADKA 1: KARTY KONTROLNE SHEWHARTA -->
            <Tab text="Karty Kontrolne Shewharta (SPC)">
                <content>
                    <VBox spacing="10.0" style="-fx-padding: 15 0 0 0;">
                        <children>
                            <HBox spacing="15.0" VBox.vgrow="ALWAYS">
                                <children>
                                    <!-- Wykres X-bar -->
                                    <VBox spacing="5.0" HBox.hgrow="ALWAYS"
                                          style="-fx-background-color: white; -fx-padding: 10; -fx-background-radius: 6px; -fx-border-color: -color-border-default; -fx-border-width: 1px;">
                                        <children>
                                            <Label text="Karta X-Bar (Średnie podgrup, n=5)"
                                                   style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: -color-accent-emphasis;" />
                                            <LineChart fx:id="xBarChart" createSymbols="true" legendVisible="false" VBox.vgrow="ALWAYS">
                                                <xAxis><NumberAxis side="BOTTOM" forceZeroInRange="false" label="Podgrupa" /></xAxis>
                                                <yAxis><NumberAxis side="LEFT" forceZeroInRange="false" label="Temperatura [°C]" /></yAxis>
                                            </LineChart>
                                        </children>
                                    </VBox>
                                    <!-- Wykres S -->
                                    <VBox spacing="5.0" HBox.hgrow="ALWAYS"
                                          style="-fx-background-color: white; -fx-padding: 10; -fx-background-radius: 6px; -fx-border-color: -color-border-default; -fx-border-width: 1px;">
                                        <children>
                                            <Label text="Karta S (Odchylenia standardowe podgrup, n=5)"
                                                   style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: -color-success-emphasis;" />
                                            <LineChart fx:id="sChart" createSymbols="true" legendVisible="false" VBox.vgrow="ALWAYS">
                                                <xAxis><NumberAxis side="BOTTOM" forceZeroInRange="false" label="Podgrupa" /></xAxis>
                                                <yAxis><NumberAxis side="LEFT" forceZeroInRange="false" label="Odchylenie S [°C]" /></yAxis>
                                            </LineChart>
                                        </children>
                                    </VBox>
                                </children>
                            </HBox>
                            <VBox spacing="5.0" VBox.vgrow="NEVER" style="-fx-padding: 5 0 0 0;">
                                <children>
                                    <Label text="Weryfikacja reguł stabilności Nelsona (Nelson Rules):"
                                           style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: -color-accent-emphasis;" />
                                    <ListView fx:id="lstNelsonViolations" prefHeight="120.0" minHeight="120.0" styleClass="audit-table">
                                        <placeholder>
                                            <Label text="✓ Wszystkie reguły stabilności Nelsona są spełnione (brak naruszeń)."
                                                   style="-fx-text-fill: #16a34a; -fx-font-weight: bold;" />
                                        </placeholder>
                                    </ListView>
                                </children>
                            </VBox>
                        </children>
                    </VBox>
                </content>
            </Tab>

            <!-- ZAKŁADKA 2: CYKLE ODSZRANIANIA (DEFROST) -->
            <Tab text="Wykryte Cykle Odszraniania (Defrost)">
                <content>
                    <VBox spacing="10.0" style="-fx-padding: 15 0 0 0;">
                        <children>
                            <Label text="Zidentyfikowane cykle odszraniania (metoda detekcji nachylenia gradientu dT/dt)"
                                   style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: -color-fg-muted;" />
                            <TableView fx:id="defrostTable" VBox.vgrow="ALWAYS" styleClass="audit-table">
                                <columns>
                                    <TableColumn fx:id="colDefrostStart"    prefWidth="180.0" text="Czas rozpoczęcia"    reorderable="false" />
                                    <TableColumn fx:id="colDefrostEnd"      prefWidth="180.0" text="Czas zakończenia"     reorderable="false" />
                                    <TableColumn fx:id="colDefrostDuration" prefWidth="120.0" text="Czas trwania [min]"   style="-fx-alignment: CENTER;" reorderable="false" />
                                    <TableColumn fx:id="colDefrostMax"      prefWidth="120.0" text="T max piku [°C]"      style="-fx-alignment: CENTER;" reorderable="false" />
                                    <TableColumn fx:id="colDefrostAmp"      prefWidth="120.0" text="Amplituda skoku [°C]" style="-fx-alignment: CENTER;" reorderable="false" />
                                </columns>
                                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                                <placeholder>
                                    <Label text="Nie wykryto cykli odszraniania w analizowanej serii danych." />
                                </placeholder>
                            </TableView>
                        </children>
                    </VBox>
                </content>
            </Tab>



        </tabs>
    </TabPane>

    <Separator />

    <!-- STOPKA PRZYCISKÓW -->
    <HBox alignment="CENTER_RIGHT" spacing="12">
        <Button onAction="#handleClose" text="Zamknij"
                style="-fx-pref-height: 38px; -fx-pref-width: 120px;" styleClass="accent" />
    </HBox>
</VBox>
