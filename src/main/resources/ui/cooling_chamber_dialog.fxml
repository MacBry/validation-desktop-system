<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefWidth="600.0" spacing="20.0" style="-fx-background-color: #f8fafc;" stylesheets="@style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.mac.bry.desktop.controller.CoolingChamberDialogController">
   <padding>
      <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
   </padding>
   <children>
      <!-- TYTUŁ OKNA -->
      <VBox spacing="5.0">
         <children>
            <Label fx:id="dialogTitleLabel" styleClass="title-2" text="Konfiguracja Komory Chłodniczej" style="-fx-text-fill: #0f172a;" />
            <Label fx:id="dialogSubtitleLabel" text="Wprowadź parametry techniczne i zakresy temperaturowe komory." style="-fx-text-fill: #64748b; -fx-font-size: 13px;" />
         </children>
      </VBox>
      
      <Separator />

      <!-- FORMULARZ DANYCH -->
      <GridPane hgap="20.0" vgap="15.0">
         <columnConstraints>
            <ColumnConstraints percentWidth="50.0" />
            <ColumnConstraints percentWidth="50.0" />
         </columnConstraints>
         <children>
            <!-- Rząd 0: Nazwa Komory i Typ Komory -->
            <VBox spacing="5.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
               <children>
                  <Label text="Nazwa Komory *:" style="-fx-font-weight: bold; -fx-text-fill: #475569;" />
                  <TextField fx:id="chamberNameField" promptText="np. Komora Górna (Chłodziarka)" style="-fx-pref-height: 38px;" />
               </children>
            </VBox>
            <VBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="0">
               <children>
                  <Label text="Typ Komory *:" style="-fx-font-weight: bold; -fx-text-fill: #475569;" />
                  <ComboBox fx:id="chamberTypeCombo" prefWidth="300.0" promptText="Wybierz typ komory..." style="-fx-pref-height: 38px;" />
               </children>
            </VBox>

            <!-- Rząd 1: Przechowywany Materiał i Objętość (m³) -->
            <VBox spacing="5.0" GridPane.columnIndex="0" GridPane.rowIndex="1">
               <children>
                  <Label text="Przechowywany Materiał:" style="-fx-font-weight: bold; -fx-text-fill: #475569;" />
                  <ComboBox fx:id="materialTypeCombo" prefWidth="300.0" promptText="Wybierz materiał..." style="-fx-pref-height: 38px;" />
               </children>
            </VBox>
            <VBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
               <children>
                  <Label text="Objętość komory (m³):" style="-fx-font-weight: bold; -fx-text-fill: #475569;" />
                  <TextField fx:id="volumeField" promptText="np. 1.25" style="-fx-pref-height: 38px;" />
               </children>
            </VBox>

            <!-- Rząd 2: Temp Min i Temp Max -->
            <VBox spacing="5.0" GridPane.columnIndex="0" GridPane.rowIndex="2">
               <children>
                  <Label text="Robocza Temp. Minimalna (°C):" style="-fx-font-weight: bold; -fx-text-fill: #475569;" />
                  <TextField fx:id="tempMinField" promptText="np. 2.0" style="-fx-pref-height: 38px;" />
               </children>
            </VBox>
            <VBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="2">
               <children>
                  <Label text="Robocza Temp. Maksymalna (°C):" style="-fx-font-weight: bold; -fx-text-fill: #475569;" />
                  <TextField fx:id="tempMaxField" promptText="np. 8.0" style="-fx-pref-height: 38px;" />
               </children>
            </VBox>

            <!-- Rząd 3: Kategoria Indicator -->
            <VBox spacing="5.0" GridPane.columnIndex="0" GridPane.rowIndex="3" GridPane.columnSpan="2">
               <children>
                  <Label text="Klasyfikacja Kubatury PDA:" style="-fx-font-weight: bold; -fx-text-fill: #475569;" />
                  <Label fx:id="volumeCategoryBadge" text="BRAK DANYCH" style="-fx-background-color: #cbd5e1; -fx-text-fill: #475569; -fx-font-weight: bold; -fx-padding: 8px 15px; -fx-background-radius: 6px; -fx-alignment: CENTER;" />
               </children>
            </VBox>
         </children>
      </GridPane>

      <!-- SEKCJA INFO METROLOGICZNEGO (PREMIUM CARD) -->
      <VBox spacing="10.0" style="-fx-background-color: #eff6ff; -fx-border-color: #bfdbfe; -fx-border-radius: 8px; -fx-background-radius: 8px; -fx-padding: 15px; -fx-border-width: 1px;">
         <children>
            <Label text="💡 Wymagania Metrologiczne Walidacji Przestrzennej (PDA TR-64):" style="-fx-font-weight: bold; -fx-text-fill: #1e3a8a; -fx-font-size: 13px;" />
            <GridPane hgap="10.0" vgap="5.0">
               <columnConstraints>
                  <ColumnConstraints prefWidth="180.0" />
                  <ColumnConstraints hgrow="ALWAYS" />
               </columnConstraints>
               <children>
                  <Label text="Kategoria komory:" style="-fx-font-weight: bold; -fx-text-fill: #1e40af;" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                  <Label fx:id="pdaCategoryLabel" text="Wprowadź pojemność, aby zobaczyć sugerowaną klasę." style="-fx-text-fill: #1e40af;" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                  
                  <Label text="Min. punkty pomiarowe:" style="-fx-font-weight: bold; -fx-text-fill: #1e40af;" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                  <Label fx:id="pdaSensorLabel" text="Brak wytycznych czujników." style="-fx-text-fill: #1e40af;" GridPane.columnIndex="1" GridPane.rowIndex="1" />
               </children>
            </GridPane>
         </children>
      </VBox>

      <!-- STOPKA - PRZYCISKI AKCJI -->
      <HBox alignment="CENTER_RIGHT" spacing="10.0">
         <children>
            <Button mnemonicParsing="false" onAction="#handleCancel" text="Anuluj" style="-fx-pref-height: 38px; -fx-pref-width: 100px;" />
            <Button fx:id="saveButton" mnemonicParsing="false" onAction="#handleSave" text="Zatwierdź" styleClass="accent" style="-fx-pref-height: 38px; -fx-pref-width: 130px; -fx-font-weight: bold;" />
         </children>
      </HBox>
   </children>
</VBox>
