<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefWidth="700.0" prefHeight="600.0" spacing="20.0" style="-fx-background-color: #f8fafc;" stylesheets="@style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.mac.bry.desktop.controller.CoolingDeviceDialogController">
   <padding>
      <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
   </padding>
   <children>
      <!-- TYTUŁ OKNA -->
      <VBox spacing="5.0">
         <children>
            <Label fx:id="dialogTitleLabel" styleClass="title-2" text="Nowe Urządzenie Chłodnicze" style="-fx-text-fill: #0f172a;" />
            <Label fx:id="dialogSubtitleLabel" text="Wprowadź dane organizacyjne fizycznego urządzenia i dodaj jego komory." style="-fx-text-fill: #64748b; -fx-font-size: 13px;" />
         </children>
      </VBox>
      
      <Separator />

      <!-- FORMULARZ DANYCH FIZYCZNYCH (GRID) -->
      <GridPane hgap="20.0" vgap="15.0">
         <columnConstraints>
            <ColumnConstraints percentWidth="50.0" />
            <ColumnConstraints percentWidth="50.0" />
         </columnConstraints>
         <children>
            <!-- Rząd 0: Numer Inwentarzowy i Nazwa -->
            <VBox spacing="5.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
               <children>
                  <Label text="Numer Inwentarzowy *:" style="-fx-font-weight: bold; -fx-text-fill: #475569;" />
                  <TextField fx:id="inventoryField" promptText="np. UC/2026/08" style="-fx-pref-height: 38px;" />
               </children>
            </VBox>
            <VBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="0">
               <children>
                  <Label text="Nazwa Urządzenia *:" style="-fx-font-weight: bold; -fx-text-fill: #475569;" />
                  <TextField fx:id="nameField" promptText="np. Chłodziarko-zamrażarka Liebherr" style="-fx-pref-height: 38px;" />
               </children>
            </VBox>

            <!-- Rząd 1: Dział i Pracownia -->
            <VBox spacing="5.0" GridPane.columnIndex="0" GridPane.rowIndex="1">
               <children>
                  <Label text="Dział *:" style="-fx-font-weight: bold; -fx-text-fill: #475569;" />
                  <ComboBox fx:id="departmentCombo" prefWidth="320.0" promptText="Wybierz dział..." style="-fx-pref-height: 38px;" />
               </children>
            </VBox>
            <VBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
               <children>
                  <Label text="Pracownia:" style="-fx-font-weight: bold; -fx-text-fill: #475569;" />
                  <ComboBox fx:id="laboratoryCombo" prefWidth="320.0" promptText="Wybierz pracownię..." style="-fx-pref-height: 38px;" />
               </children>
            </VBox>
            <!-- Rząd 2: Status urządzenia -->
            <VBox spacing="5.0" GridPane.columnIndex="0" GridPane.rowIndex="2">
               <children>
                  <Label text="Status urządzenia *:" style="-fx-font-weight: bold; -fx-text-fill: #475569;" />
                  <ComboBox fx:id="statusCombo" prefWidth="320.0" promptText="Wybierz status..." style="-fx-pref-height: 38px;" />
               </children>
            </VBox>
         </children>
      </GridPane>

      <Separator />

      <!-- SEKCJA KOMÓR CHŁODNICZYCH -->
      <VBox spacing="10.0" VBox.vgrow="ALWAYS">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="10">
               <children>
                  <Label text="Komory Urządzenia * (Musi posiadać co najmniej jedną komorę):" style="-fx-font-weight: bold; -fx-text-fill: #334155; -fx-font-size: 14px;" HBox.hgrow="ALWAYS" />
                  <Region HBox.hgrow="ALWAYS" />
                  <HBox spacing="8">
                     <children>
                        <Button fx:id="addChamberButton" onAction="#handleAddChamber" text="+ Dodaj Komorę" styleClass="button-sm" />
                        <Button fx:id="editChamberButton" onAction="#handleEditChamber" text="Edytuj" styleClass="button-sm, success" />
                        <Button fx:id="deleteChamberButton" onAction="#handleDeleteChamber" text="Usuń" styleClass="button-sm, danger" />
                     </children>
                  </HBox>
               </children>
            </HBox>
            
            <TableView fx:id="chambersTable" VBox.vgrow="ALWAYS" styleClass="audit-table">
               <columns>
                  <TableColumn fx:id="chamberNameCol" prefWidth="150" text="Nazwa komory" />
                  <TableColumn fx:id="chamberTypeCol" prefWidth="130" text="Typ komory" />
                  <TableColumn fx:id="chamberRangeCol" prefWidth="130" text="Zakres roboczy" style="-fx-alignment: CENTER;" />
                  <TableColumn fx:id="chamberVolumeCol" prefWidth="100" text="Objętość" style="-fx-alignment: CENTER;" />
                  <TableColumn fx:id="chamberMaterialCol" prefWidth="150" text="Materiał" />
               </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
         </children>
      </VBox>

      <!-- STOPKA - PRZYCISKI AKCJI -->
      <HBox alignment="CENTER_RIGHT" spacing="10.0">
         <children>
            <Button mnemonicParsing="false" onAction="#handleCancel" text="Anuluj" style="-fx-pref-height: 38px; -fx-pref-width: 100px;" />
            <Button fx:id="saveButton" mnemonicParsing="false" onAction="#handleSave" text="Zapisz urządzenie" styleClass="accent" style="-fx-pref-height: 38px; -fx-pref-width: 160px; -fx-font-weight: bold;" />
         </children>
      </HBox>
   </children>
</VBox>
