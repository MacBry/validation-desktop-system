<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox spacing="25.0" xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.mac.bry.desktop.controller.AdminMaterialsController"
      stylesheets="@style.css">
    <padding>
        <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
    </padding>
    <children>
        <!-- SEKCJA TABELI SŁOWNIKA -->
        <VBox HBox.hgrow="ALWAYS" spacing="15.0">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="15">
                    <children>
                        <Label text="%adminmaterials.slownik_kategorii_przechowywanych_materialow"
                               style="-fx-font-weight: bold; -fx-font-size: 20px; -fx-text-fill: #0f172a;" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button mnemonicParsing="false" onAction="#handleNewMaterial"
                                text="%adminmaterials.nowy_material" styleClass="accent"
                                style="-fx-pref-height: 38px; -fx-font-weight: bold;" />
                    </children>
                </HBox>

                <TableView fx:id="materialsTable" VBox.vgrow="ALWAYS" styleClass="audit-table">
                    <columns>
                        <TableColumn fx:id="materialNameCol" prefWidth="150.0" text="%adminmaterials.nazwa" />
                        <TableColumn fx:id="materialTempCol" prefWidth="140.0" text="%adminmaterials.zakres_temp"
                                     style="-fx-alignment: CENTER;" />
                        <TableColumn fx:id="materialEaCol" prefWidth="120.0" text="%adminmaterials.ea_kj_mol"
                                     style="-fx-alignment: CENTER;" />
                        <TableColumn fx:id="materialSourceCol" prefWidth="180.0" text="%adminmaterials.standard_norma" />
                        <TableColumn fx:id="materialRequiresMappingCol" prefWidth="130.0" text="%adminmaterials.wymaga_mapowania"
                                     style="-fx-alignment: CENTER;" />
                        <TableColumn fx:id="materialActiveCol" prefWidth="100.0" text="%common.status"
                                     style="-fx-alignment: CENTER;" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </children>
        </VBox>

        <!-- PANEL SZCZEGÓŁÓW (SIDE CARD) -->
        <VBox prefWidth="380.0" spacing="15.0"
              style="-fx-background-color: white; -fx-background-radius: 12px; -fx-padding: 20px;
                     -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 15, 0, 0, 5);">
            <children>
                <Label text="%adminmaterials.szczegoly_materialu"
                       style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #0f172a;" />
                <Label fx:id="selectedMaterialLabel"
                       text="%adminmaterials.wybierz_material_z_listy"
                       style="-fx-font-size: 13px; -fx-text-fill: #64748b;" />

                <Separator />

                <VBox spacing="10.0">
                    <children>
                        <Label text="%adminmaterials.nazwa_materialu" style="-fx-font-weight: bold; -fx-text-fill: #475569;" />
                        <TextField fx:id="materialNameField" style="-fx-pref-height: 36px;" />

                        <Label text="%adminmaterials.opis_zastosowanie" style="-fx-font-weight: bold; -fx-text-fill: #475569;" />
                        <TextField fx:id="materialDescField" style="-fx-pref-height: 36px;" />

                        <HBox spacing="10.0">
                            <children>
                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="%adminmaterials.temp_min_c"
                                               style="-fx-font-weight: bold; -fx-text-fill: #475569;" />
                                        <TextField fx:id="materialTempMinField" style="-fx-pref-height: 36px;" />
                                    </children>
                                </VBox>
                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="%adminmaterials.temp_max_c"
                                               style="-fx-font-weight: bold; -fx-text-fill: #475569;" />
                                        <TextField fx:id="materialTempMaxField" style="-fx-pref-height: 36px;" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <Label text="%adminmaterials.energia_aktywacji_ea_kj"
                               style="-fx-font-weight: bold; -fx-text-fill: #475569;" />
                        <TextField fx:id="materialEaField" style="-fx-pref-height: 36px;" />

                        <Label text="%adminmaterials.standard_norma_zrodlowa"
                               style="-fx-font-weight: bold; -fx-text-fill: #475569;" />
                        <TextField fx:id="materialSourceField" style="-fx-pref-height: 36px;" />

                        <CheckBox fx:id="materialRequiresMappingCheckbox" text="%adminmaterials.wymaga_mapowania_komory"
                                  style="-fx-font-weight: bold; -fx-text-fill: #475569; -fx-padding: 5px 0px;" />
                        <CheckBox fx:id="materialActiveCheckbox" text="%adminmaterials.aktywny_w_slowniku"
                                  style="-fx-font-weight: bold; -fx-text-fill: #475569; -fx-padding: 5px 0px;" />
                    </children>
                </VBox>

                <Separator />

                <HBox alignment="CENTER_RIGHT" spacing="8.0">
                    <children>
                        <Button mnemonicParsing="false" onAction="#handleMaterialAudit"
                                styleClass="button-sm"
                                style="-fx-background-color: #64748b; -fx-text-fill: white; -fx-font-weight: bold;"
                                text="%common.audit" />
                        <Button mnemonicParsing="false" onAction="#handleSaveMaterial"
                                styleClass="button-sm"
                                style="-fx-background-color: #0f172a; -fx-text-fill: white; -fx-font-weight: bold;"
                                text="%common.zapisz" />
                    </children>
                </HBox>
                <Label fx:id="materialStatusLabel" text="" wrapText="true"
                       style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #10b981;" />
            </children>
        </VBox>
    </children>
</HBox>
