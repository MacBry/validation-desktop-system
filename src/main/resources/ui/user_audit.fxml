<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="600.0" prefWidth="900.0" spacing="15.0" styleClass="content-pane" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mac.bry.desktop.controller.UserAuditController">
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
   <children>
      <HBox alignment="CENTER_LEFT" spacing="20.0">
         <children>
            <VBox>
               <children>
                  <Label fx:id="mainTitleLabel" styleClass="title-2" text="Historia Audytu" />
                  <Label fx:id="userInfoLabel" style="-fx-text-fill: -color-fg-muted;" text="Użytkownik: [nazwa]" />
               </children>
            </VBox>
         </children>
      </HBox>
      
      <TableView fx:id="auditTable" styleClass="striped" VBox.vgrow="ALWAYS">
        <columns>
          <TableColumn fx:id="dateColumn" prefWidth="150.0" text="Data i Godzina" />
          <TableColumn fx:id="adminColumn" prefWidth="120.0" text="Wykonawca" />
          <TableColumn fx:id="typeColumn" prefWidth="100.0" text="Operacja" />
          <TableColumn fx:id="fieldColumn" prefWidth="120.0" text="Pole" />
          <TableColumn fx:id="oldValueColumn" prefWidth="180.0" text="Stara Wartość" />
          <TableColumn fx:id="newValueColumn" prefWidth="180.0" text="Nowa Wartość" />
        </columns>
      </TableView>
      
      <HBox alignment="CENTER_RIGHT" spacing="10.0">
         <children>
            <Button mnemonicParsing="false" onAction="#handleExportPdf" prefHeight="30.0" prefWidth="120.0" styleClass="danger" text="Eksport PDF" />
            <Button mnemonicParsing="false" onAction="#handleExportCsv" prefHeight="30.0" prefWidth="120.0" styleClass="success" text="Eksport CSV" />
            <Button mnemonicParsing="false" onAction="#handleClose" prefHeight="30.0" prefWidth="100.0" text="Zamknij" />
         </children>
      </HBox>
   </children>
</VBox>
