<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.mac.bry.desktop.controller.UserDialogController" prefWidth="650" prefHeight="640" styleClass="content-area" stylesheets="@style.css">
    <padding>
        <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
    </padding>

    <!-- NAGŁÓWEK DIALOGU -->
    <Label fx:id="titleLabel" styleClass="title-2" text="%userdialog.nowy_uzytkownik_systemu" style="-fx-font-weight: bold; -fx-text-fill: #0f172a;" />
    
    <!-- PANEL GŁÓWNY (GRID FORM) -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-width: 0;">
        <content>
            <VBox spacing="15">
                <!-- DANE LOGOWANIA -->
                <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 15px; -fx-background-radius: 8px; -fx-border-color: #cbd5e1; -fx-border-radius: 8px;">
                    <children>
                        <Label text="%userdialog.dane_logowania_i_bezpieczenstwa" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #94a3b8; -fx-letter-spacing: 1px;" />
                        <GridPane hgap="15" vgap="12">
                            <columnConstraints>
                                <ColumnConstraints prefWidth="140" />
                                <ColumnConstraints hgrow="ALWAYS" />
                            </columnConstraints>
                            <children>
                                <Label text="%userdialog.login_nazwa_uzytkownika" style="-fx-font-weight: bold; -fx-text-fill: #475569;" GridPane.rowIndex="0" />
                                <TextField fx:id="usernameField" promptText="%userdialog.np_j_kowalski" style="-fx-pref-height: 36px;" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                                <Label text="%userdialog.tymczasowe_haslo" style="-fx-font-weight: bold; -fx-text-fill: #475569;" GridPane.rowIndex="1" />
                                <PasswordField fx:id="passwordField" promptText="%userdialog.wpisz_haslo_startowe" style="-fx-pref-height: 36px;" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                                <Label text="%userdialog.e_mail" style="-fx-font-weight: bold; -fx-text-fill: #475569;" GridPane.rowIndex="2" />
                                <TextField fx:id="emailField" promptText="%common.np_jan_kowalski_vcc" style="-fx-pref-height: 36px;" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                            </children>
                        </GridPane>
                        
                        <Separator />
                        
                        <VBox spacing="8">
                            <children>
                                <CheckBox fx:id="enabledCheckbox" text="%userdialog.konto_aktywne_zezwol_na" selected="true" style="-fx-font-weight: bold; -fx-text-fill: #475569;" />
                                <CheckBox fx:id="mustChangePasswordCheckbox" text="%userdialog.wymus_zmiane_hasla_przy" selected="true" style="-fx-font-weight: bold; -fx-text-fill: #475569;" />
                            </children>
                        </VBox>
                    </children>
                </VBox>

                <!-- DANE OSOBOWE -->
                <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 15px; -fx-background-radius: 8px; -fx-border-color: #cbd5e1; -fx-border-radius: 8px;">
                    <children>
                        <Label text="%userdialog.dane_osobowe_i_jednostka" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #94a3b8; -fx-letter-spacing: 1px;" />
                        <GridPane hgap="15" vgap="12">
                            <columnConstraints>
                                <ColumnConstraints prefWidth="140" />
                                <ColumnConstraints hgrow="ALWAYS" />
                            </columnConstraints>
                            <children>
                                <Label text="%userdialog.imie" style="-fx-font-weight: bold; -fx-text-fill: #475569;" GridPane.rowIndex="0" />
                                <TextField fx:id="firstNameField" promptText="%common.imie" style="-fx-pref-height: 36px;" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                                <Label text="%userdialog.nazwisko" style="-fx-font-weight: bold; -fx-text-fill: #475569;" GridPane.rowIndex="1" />
                                <TextField fx:id="lastNameField" promptText="%common.nazwisko" style="-fx-pref-height: 36px;" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                                <Label text="%common.dzial2" style="-fx-font-weight: bold; -fx-text-fill: #475569;" GridPane.rowIndex="2" />
                                <ComboBox fx:id="deptComboBox" prefWidth="450.0" promptText="%common.wybierz_dzial" style="-fx-pref-height: 36px;" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                                <Label text="%common.pracownia2" style="-fx-font-weight: bold; -fx-text-fill: #475569;" GridPane.rowIndex="3" />
                                <ComboBox fx:id="labComboBox" prefWidth="450.0" promptText="%common.wybierz_pracownie" style="-fx-pref-height: 36px;" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                            </children>
                        </GridPane>
                    </children>
                </VBox>

                <!-- ROLE ZABEZPIECZEŃ -->
                <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 15px; -fx-background-radius: 8px; -fx-border-color: #cbd5e1; -fx-border-radius: 8px;">
                    <children>
                        <Label text="%userdialog.role_i_uprawnienia_bezpieczenstwa" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #94a3b8; -fx-letter-spacing: 1px;" />
                        <ScrollPane fitToWidth="true" prefHeight="100.0" style="-fx-background-color: transparent; -fx-border-color: #cbd5e1; -fx-border-radius: 6px;">
                           <content>
                              <VBox fx:id="rolesContainer" spacing="6.0" style="-fx-padding: 8px;" />
                           </content>
                        </ScrollPane>
                    </children>
                </VBox>
            </VBox>
        </content>
    </ScrollPane>

    <Label fx:id="errorLabel" style="-fx-text-fill: #dc2626; -fx-font-weight: bold;" wrapText="true" visible="false" />

    <Separator />

    <!-- STOPKA PRZYCISKÓW -->
    <HBox alignment="CENTER_RIGHT" spacing="12">
        <Button onAction="#handleCancel" text="%common.anuluj" style="-fx-pref-height: 38px; -fx-pref-width: 100px;" />
        <Button onAction="#handleSave" styleClass="accent" text="%userdialog.utworz_uzytkownika" style="-fx-pref-height: 38px; -fx-font-weight: bold;" />
    </HBox>
</VBox>
