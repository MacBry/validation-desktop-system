<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<HBox spacing="25.0" style="-fx-background-color: #f1f5f9; -fx-padding: 30;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mac.bry.desktop.controller.UserProfileController" stylesheets="@style.css">
   <children>
      <!-- LEWA KARTA: PODGLĄD PROFILU & AVATAR -->
      <VBox alignment="TOP_CENTER" prefWidth="300.0" spacing="20.0" style="-fx-background-color: white; -fx-background-radius: 12px; -fx-padding: 30px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 15, 0, 0, 5);">
         <children>
            <!-- DYNAMICZNY OKRĄGŁY AVATAR Z INICJAŁAMI -->
            <StackPane alignment="CENTER" style="-fx-background-color: #0f172a; -fx-background-radius: 50px; -fx-min-width: 90px; -fx-min-height: 90px; -fx-max-width: 90px; -fx-max-height: 90px;">
               <children>
                  <Label fx:id="avatarInitialsLabel" text="%userprofile.mb" textFill="WHITE" style="-fx-font-size: 32px; -fx-font-weight: bold;" />
               </children>
            </StackPane>
            
            <!-- INFORMACJE PODSTAWOWE -->
            <VBox alignment="CENTER" spacing="5.0">
               <children>
                  <Label fx:id="fullNameLabel" text="%userprofile.maciej_bry" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #0f172a;" />
                  <Label fx:id="emailLabel" text="%userprofile.maciej_bry_vcc_pl" style="-fx-font-size: 13px; -fx-text-fill: #64748b;" />
               </children>
            </VBox>
            
            <Separator />
            
            <!-- ROLA SYSTEMOWA (BADGE) -->
            <VBox alignment="CENTER" spacing="8.0">
               <children>
                  <Label text="%userprofile.rola_systemowa" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #94a3b8; -fx-letter-spacing: 1px;" />
                  <Label fx:id="roleBadgeLabel" text="%userprofile.super_admin" styleClass="tag" style="-fx-background-color: #dbeafe; -fx-text-fill: #1d4ed8; -fx-background-radius: 12px; -fx-padding: 4px 10px; -fx-font-weight: bold; -fx-font-size: 11px;" />
               </children>
            </VBox>
            
            <Separator />
            
            <VBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-background-color: #f8fafc; -fx-padding: 15px; -fx-background-radius: 8px;">
               <children>
                  <Label text="%userprofile.wskazowka_bezpieczenstwa" style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #334155;" />
                  <Label text="%userprofile.pamietaj_aby_regularnie_zmieniac" wrapText="true" style="-fx-font-size: 11px; -fx-text-fill: #64748b; -fx-line-spacing: 3px;" />
               </children>
            </VBox>
         </children>
      </VBox>
      
      <!-- PRAWA KARTA: FORMULARZE EDYCJI DANYCH -->
      <VBox HBox.hgrow="ALWAYS" spacing="25.0">
         <children>
            <!-- DANE PODSTAWOWE -->
            <VBox spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 12px; -fx-padding: 25px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 15, 0, 0, 5);">
               <children>
                  <Label text="%userprofile.dane_podstawowe_profilu" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #0f172a;" />
                  
                  <GridPane hgap="20.0" vgap="15.0">
                     <columnConstraints>
                        <ColumnConstraints percentWidth="50" />
                        <ColumnConstraints percentWidth="50" />
                     </columnConstraints>
                     <children>
                        <VBox spacing="5.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                           <children>
                              <Label text="%common.imie" style="-fx-font-weight: bold; -fx-text-fill: #475569;" />
                              <TextField fx:id="firstNameField" promptText="%userprofile.wpisz_imie" style="-fx-pref-height: 38px;" />
                           </children>
                        </VBox>
                        <VBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="0">
                           <children>
                              <Label text="%common.nazwisko" style="-fx-font-weight: bold; -fx-text-fill: #475569;" />
                              <TextField fx:id="lastNameField" promptText="%userprofile.wpisz_nazwisko" style="-fx-pref-height: 38px;" />
                           </children>
                        </VBox>
                        <VBox spacing="5.0" GridPane.columnIndex="0" GridPane.rowIndex="1">
                           <children>
                              <Label text="%userprofile.adres_e_mail" style="-fx-font-weight: bold; -fx-text-fill: #475569;" />
                              <TextField fx:id="emailField" promptText="%common.np_jan_kowalski_vcc" style="-fx-pref-height: 38px;" />
                           </children>
                        </VBox>
                        <VBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
                           <children>
                              <Label text="%userprofile.numer_telefonu" style="-fx-font-weight: bold; -fx-text-fill: #475569;" />
                              <TextField fx:id="phoneField" promptText="%userprofile.np_48_123_456" style="-fx-pref-height: 38px;" />
                           </children>
                        </VBox>
                     </children>
                  </GridPane>
                  
                  <HBox alignment="CENTER_LEFT" spacing="15.0">
                     <children>
                        <Button mnemonicParsing="false" onAction="#handleSaveProfile" styleClass="accent" text="%userprofile.zapisz_zmiany_danych" style="-fx-pref-height: 38px; -fx-font-weight: bold;" />
                        <Label fx:id="profileMessageLabel" style="-fx-font-weight: bold; -fx-font-size: 13px;" visible="false" />
                     </children>
                     <VBox.margin>
                        <Insets top="10.0" />
                     </VBox.margin>
                  </HBox>
               </children>
            </VBox>
            
            <!-- ZMIANA HASŁA (Z REAKTYWNYM WSKAŹNIKIEM SIŁY) -->
            <VBox spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 12px; -fx-padding: 25px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 15, 0, 0, 5);">
               <children>
                  <Label text="%userprofile.zabezpieczenia_i_zmiana_hasla" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #0f172a;" />
                  
                  <GridPane hgap="20.0" vgap="15.0">
                     <columnConstraints>
                        <ColumnConstraints percentWidth="33.3" />
                        <ColumnConstraints percentWidth="33.3" />
                        <ColumnConstraints percentWidth="33.3" />
                     </columnConstraints>
                     <children>
                        <VBox spacing="5.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                           <children>
                              <Label text="%userprofile.obecne_haslo" style="-fx-font-weight: bold; -fx-text-fill: #475569;" />
                              <PasswordField fx:id="oldPasswordField" promptText="%userprofile.wpisz_obecne_haslo" style="-fx-pref-height: 38px;" />
                           </children>
                        </VBox>
                        <VBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="0">
                           <children>
                              <Label text="%userprofile.nowe_haslo" style="-fx-font-weight: bold; -fx-text-fill: #475569;" />
                              <PasswordField fx:id="newPasswordField" promptText="%common.wpisz_nowe_haslo" style="-fx-pref-height: 38px;" />
                              <!-- Pasek siły hasła z etykietą -->
                              <HBox spacing="8" alignment="CENTER_LEFT">
                                 <children>
                                    <ProgressBar fx:id="passwordStrengthBar" prefWidth="100.0" progress="0.0" style="-fx-pref-height: 6px;" />
                                    <Label fx:id="passwordStrengthLabel" style="-fx-font-size: 11px; -fx-font-weight: bold;" />
                                 </children>
                              </HBox>
                           </children>
                        </VBox>
                        <VBox spacing="5.0" GridPane.columnIndex="2" GridPane.rowIndex="0">
                           <children>
                              <Label text="%common.powtorz_nowe_haslo" style="-fx-font-weight: bold; -fx-text-fill: #475569;" />
                              <PasswordField fx:id="confirmNewPasswordField" promptText="%common.powtorz_nowe_haslo" style="-fx-pref-height: 38px;" />
                           </children>
                        </VBox>
                     </children>
                  </GridPane>
                  
                  <HBox alignment="CENTER_LEFT" spacing="15.0">
                     <children>
                        <Button mnemonicParsing="false" onAction="#handleChangePassword" style="-fx-background-color: #dc2626; -fx-text-fill: white; -fx-pref-height: 38px; -fx-font-weight: bold; -fx-cursor: hand;" text="%userprofile.zmien_haslo" />
                        <Label fx:id="passwordMessageLabel" style="-fx-font-weight: bold; -fx-font-size: 13px;" visible="false" />
                     </children>
                     <VBox.margin>
                        <Insets top="10.0" />
                     </VBox.margin>
                  </HBox>
               </children>
            </VBox>
         </children>
      </VBox>
   </children>
</HBox>
