# Tryb bazy danych:
#   server     = MySQL (domyślny; wymaga zainstalowanego serwera MySQL)
#   standalone = wbudowana baza H2 w pliku ./data/validation_desktop.mv.db
#                (zero instalacji — dla pojedynczego stanowiska / małych laboratoriów)
DB_MODE=server

# Baza Danych MySQL (tylko tryb server)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=validation_desktop_db
DB_USERNAME=root
DB_PASSWORD=your_database_password

# Ścieżka do narzędzia mysqldump (do kopii zapasowych)
MYSQL_DUMP_PATH=C:\Program Files\MySQL\MySQL Server 8.0\bin\mysqldump.exe

# Konfiguracja SMTP (np. Brevo)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password
