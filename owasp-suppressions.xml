<?xml version="1.0" encoding="UTF-8"?>
<!--
  Plik supresji OWASP Dependency-Check.
  Dodawaj tu wpisy dla potwierdzonych false-positive lub podatności nie dotyczących
  sposobu użycia zależności w tym projekcie. Każdy wpis powinien mieć uzasadnienie i CVE.

  Przykład:
  <suppress>
      <notes>FP: podatność dotyczy komponentu serwerowego, nie używanego w tej aplikacji.</notes>
      <packageUrl regex="true">^pkg:maven/com\.example/.*$</packageUrl>
      <cve>CVE-YYYY-NNNNN</cve>
  </suppress>
-->
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">

    <!-- log4j-api / log4j-to-slf4j: w projekcie obecny JEST tylko most Log4j2->SLF4J
         (log4j-to-slf4j) oraz samo API (log4j-api). log4j-CORE NIE jest na classpath
         (potwierdzone `mvn dependency:tree`), runtime logowania to Logback. Poniższe CVE
         dotyczą kodu Log4j2, którego u nas nie ma / nie wykonujemy (m.in. Log4j1XmlLayout
         z mostka Log4j1->2). Niewykorzystywane -> supresja. Przegląd przy zmianie stosu logów. -->
    <suppress>
        <notes>FP: brak log4j-core; runtime = Logback. Log4j1XmlLayout z mostka nieużywany.</notes>
        <packageUrl regex="true">^pkg:maven/org\.apache\.logging\.log4j/log4j-(api|to-slf4j)@.*$</packageUrl>
        <cve>CVE-2026-34479</cve>
        <cve>CVE-2026-34477</cve>
        <cve>CVE-2026-49844</cve>
    </suppress>

</suppressions>
